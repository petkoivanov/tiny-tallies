{
  "expo": {
    "name": "Tiny Tallies",
    "slug": "tiny-tallies",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.magicmirror.tinytallies",
      "buildNumber": "2",
      "icon": "./assets/icon.png",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.magicmirror.tinytallies",
      "versionCode": 2,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.83762615868-7m9m4hbfuke1n3lnp3dia3e49bplnu13"
        }
      ],
      "./plugins/withUnifiedKeystore",
      [
        "@sentry/react-native/expo",
        {
          "organization": "magic-mirror-works",
          "project": "tiny-tallies"
        }
      ]
    ],
    "owner": "magic.mirror.works",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "REPLACE_WITH_EXPO_UPDATES_URL"
    }
  }
}
